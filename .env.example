# Copy to .env and fill in. Get keys at https://alpaca.markets (free).
# Paper account keys are different from live keys — use paper keys while testing.

ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# SAFETY GATE: "true" = simulated paper money (default), "false" = REAL money.
# Going live also requires passing --i-understand-the-risk on the trade command.
ALPACA_PAPER=true
